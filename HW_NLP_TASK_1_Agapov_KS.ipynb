        "## 3. BM25"
      ],
      "metadata": {
        "id": "H7EhIz--MisF"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "def tokenize(text: str) -> list[str]:\n",
        "    # Простая токенизация: строчные буквы, убираем пунктуацию\n",
        "    return re.findall(r'\\b[a-zA-Z]{2,}\\b', text.lower())\n",
        "\n",
        "print('Строим BM25 индекс')\n",
        "tokenized_corpus = [tokenize(line) for line in lines]\n",
        "bm25 = BM25Okapi(tokenized_corpus)\n",
        "print(f'BM25 индекс построен из {len(lines)} документов')"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "TcTBVTO4Oyec",
