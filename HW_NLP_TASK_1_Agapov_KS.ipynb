      "source": [
        "DIM = embeddings.shape[1]  # 384\n",
        "\n",
        "# Точный поиск\n",
        "index_exact = faiss.IndexFlatIP(DIM)\n",
        "index_exact.add(embeddings.astype(np.float32))\n",
        "\n",
        "# Приближённый поиск IVF\n",
        "N = len(lines)\n",
        "NLIST = min(100, N // 10)  # число кластеров\n",
        "quantizer = faiss.IndexFlatIP(DIM)\n",
        "index_ivf = faiss.IndexIVFFlat(quantizer, DIM, NLIST, faiss.METRIC_INNER_PRODUCT)\n",
        "index_ivf.train(embeddings.astype(np.float32))\n",
        "index_ivf.add(embeddings.astype(np.float32))\n",
        "index_ivf.nprobe = 10  # сколько кластеров проверять при поиске\n",
        "\n",
        "print(f'FAISS индекс построен')\n",
        "print(f'Exact(IndexFlatIP):  {index_exact.ntotal} векторов')\n",
        "print(f'ANN(IndexIVFFlat): {index_ivf.ntotal} векторов, nlist={NLIST} при nprobe=10')\n",
        "\n",
        "# Сохраняем индексы на диск\n",
        "faiss.write_index(index_exact, 'faiss_exact.index')\n",
        "faiss.write_index(index_ivf, 'faiss_ivf.index')\n",
        "np.save('embeddings.npy', embeddings)\n",
        "print('Индексы и эмбеддинги сохранены в файл embeddings.npy')"
      ],
