      "cell_type": "code",
      "source": [
        "benchmark_queries = [\n",
        "    \"What do you think about this universe?\",\n",
        "    \"I don't need your help\",\n",
        "    \"Time travel is boring\",\n",
        "    \"Let's get out of here\",\n",
        "    \"Pickle Rick\",\n",
        "] * 500  # 100 запросов\n",
        "\n",
        "REPEATS = 100\n",
        "\n",
        "# FAISS Exact\n",
        "t0 = time.time()\n",
        "for q in benchmark_queries[:REPEATS]:\n",
        "    vector_search(q, use_ivf=False)\n",
        "faiss_exact_time = (time.time() - t0) / REPEATS * 1000\n",
        "\n",
        "# FAISS IVF\n",
        "QUERY_CACHE.clear()\n",
        "t0 = time.time()\n",
        "for q in benchmark_queries[:REPEATS]:\n",
        "    vector_search(q, use_ivf=True)\n",
        "faiss_ivf_time = (time.time() - t0) / REPEATS * 1000\n",
        "\n",
        "# BM25\n",
        "t0 = time.time()\n",
        "for q in benchmark_queries[:REPEATS]:\n",
        "    bm25_search(q)\n",
        "bm25_time = (time.time() - t0) / REPEATS * 1000\n",
        "\n",
        "# С кэшем (vector)\n",
        "t0 = time.time()\n",
        "for q in benchmark_queries[:REPEATS]:  # те же запросы → из кэша\n",
        "    vector_search(q, use_ivf=False)\n",
        "faiss_cached_time = (time.time() - t0) / REPEATS * 1000\n",
        "\n",
        "print('Среднее время на запрос (мс):')\n",
        "print(f'FAISS IndexFlatIP: {faiss_exact_time:.2f} ms')\n",
        "print(f'FAISS IndexIVFFlat (ANN): {faiss_ivf_time:.2f} ms')\n",
        "print(f'FAISS + query cache: {faiss_cached_time:.3f} ms')\n",
        "print(f'BM25 keyword search: {bm25_time:.2f} ms')\n",
        "print(f'\\nКэш ускоряет vector search в ~{faiss_exact_time/max(faiss_cached_time,0.001):.0f} раз')"
      ],
