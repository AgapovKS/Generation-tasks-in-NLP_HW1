    {
      "cell_type": "markdown",
      "source": [
        "## 4. Инференс"
      ],
      "metadata": {
        "id": "gfm2T60qNBmA"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "QUERY_CACHE: dict[str, np.ndarray] = {}\n",
        "\n",
        "\n",
        "def encode_query(query: str) -> np.ndarray:\n",
        "    # Кодирует запрос с кэшированием\n",
        "    if query not in QUERY_CACHE:\n",
        "        vec = model.encode(\n",
        "            [query],\n",
        "            normalize_embeddings=True,\n",
        "            convert_to_numpy=True\n",
        "        )\n",
        "        QUERY_CACHE[query] = vec\n",
        "    return QUERY_CACHE[query]\n",
        "\n",
        "\n",
        "def vector_search(query: str, top_k: int = 5, use_ivf: bool = False) -> list[dict]:\n",
        "    \"\"\"\n",
        "    Векторный поиск через FAISS.\n",
        "\n",
        "    Аргументы:\n",
        "        query:   Запрос пользователя\n",
        "        top_k:   Сколько результатов вернуть\n",
        "        use_ivf: True = приближённый, False = точный\n",
        "\n",
        "    Возвращаем:\n",
        "        Список словарей {rank, line, score}\n",
        "    \"\"\"\n",
        "    q_vec = encode_query(query).astype(np.float32)\n",
        "    idx = index_ivf if use_ivf else index_exact\n",
        "    scores, indices = idx.search(q_vec, top_k)\n",
        "\n",
        "    results = []\n",
        "    for rank, (score, idx_) in enumerate(zip(scores[0], indices[0]), 1):\n",
        "        if idx_ >= 0:  # FAISS возвращает -1 если не нашёл\n",
        "            results.append({\n",
        "                'rank': rank,\n",
        "                'line': lines[idx_],\n",
        "                'score': float(score),\n",
        "                'index': int(idx_)\n",
        "            })\n",
        "    return results\n",
        "\n",
        "# Keyword-поиск через BM25.\n",
        "def bm25_search(query: str, top_k: int = 5) -> list[dict]:\n",
        "\n",
        "    tokens = tokenize(query)\n",
        "    scores = bm25.get_scores(tokens)\n",
        "    top_indices = np.argsort(scores)[::-1][:top_k]\n",
        "\n",
        "    results = []\n",
        "    for rank, idx_ in enumerate(top_indices, 1):\n",
        "        results.append({\n",
        "            'rank': rank,\n",
        "            'line': lines[idx_],\n",
        "            'score': float(scores[idx_]),\n",
        "            'index': int(idx_)\n",
        "        })\n",
        "    return results\n",
        "\n",
        "\n",
        "def chat(query: str, top_k: int = 1, verbose: bool = True) -> str:\n",
        "    \"\"\"\n",
        "    Основная функция чат-бота.\n",
        "    Возвращает лучшую реплику Рика для данного запроса.\n",
        "\n",
        "    Args:\n",
        "        query:   Запрос пользователя\n",
        "        top_k:   Сколько альтернатив показать\n",
        "        verbose: Выводить ли детали\n",
        "    \"\"\"\n",
        "    results = vector_search(query, top_k=top_k)\n",
        "    best = results[0]\n",
        "\n",
        "    if verbose:\n",
        "        print(f'Вы: {query}')\n",
        "        print(f'Рик (similarity={best[\"score\"]:.4f}): {best[\"line\"]}')\n",
        "        if top_k > 1:\n",
        "            print(f'\\n   Альтернативы:')\n",
        "            for r in results[1:]:\n",
        "                print(f'   [{r[\"rank\"]}] (sim={r[\"score\"]:.4f}) {r[\"line\"]}')\n",
        "\n",
        "    return best['line']\n"
      ],
      "metadata": {
        "id": "pWcxtwy2XPlS"
      },
      "execution_count": 14,
      "outputs": []
    },
