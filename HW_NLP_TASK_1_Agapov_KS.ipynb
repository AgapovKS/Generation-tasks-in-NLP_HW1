        "# интерактивный интерфейс\n",
        "def interactive_chat():\n",
        "    print('Чат-бот Рик')\n",
        "    print('Введите \"quit\" для выхода | \"top3\" перед запросом для альтернатив')\n",
        "    print('Старт')\n",
        "\n",
        "    while True:\n",
        "        try:\n",
        "            user_input = input('\\n Вы: ').strip()\n",
        "        except (EOFError, KeyboardInterrupt):\n",
        "            print('\\nРик: Later, Morty.')\n",
        "            break\n",
        "\n",
        "        if not user_input:\n",
        "            continue\n",
        "        if user_input.lower() == 'quit':\n",
        "            print('Рик: bye bye')\n",
        "            break\n",
        "\n",
        "        top_k = 1\n",
        "        if user_input.lower().startswith('top3 '):\n",
        "            top_k = 3\n",
        "            user_input = user_input[5:]\n",
        "\n",
        "        results = vector_search(user_input, top_k=top_k)\n",
        "        best = results[0]\n",
        "        print(f'Рик (sim={best[\"score\"]:.4f}): {best[\"line\"]}')\n",
        "        if top_k > 1:\n",
        "            for r in results[1:]:\n",
        "                print(f'alt [{r[\"rank\"]}] (sim={r[\"score\"]:.4f}): {r[\"line\"]}')\n",
        "\n",
        "\n",
        " # interactive_chat()\n",
        "\n",
        "print('Раскомментируйте interactive_chat() выше для запуска чата')"
