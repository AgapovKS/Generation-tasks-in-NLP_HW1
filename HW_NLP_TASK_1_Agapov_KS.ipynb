      "source": [
        "## 1. Обработка данных"
      ],
      "metadata": {
        "id": "2cwb2gcew0Sw"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "print('Топ-15 персонажей по репликам:')\n",
        "print(df_raw['name'].value_counts().head(15))"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "8yQRrX_GjKY4",
        "outputId": "38bd8227-f030-44e3-f133-b990ccdf7061"
      },
      "execution_count": 5,
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Топ-15 персонажей по репликам:\n",
            "name\n",
            "Rick                  420\n",
            "Morty                 347\n",
            "Beth                  148\n",
            "Jerry                 132\n",
            "Summer                 97\n",
            "Pickle Rick            77\n",
            "Supernova              44\n",
            "Cop Morty              34\n",
            "All Ricks              32\n",
            "Mr. Goldenfold         28\n",
            "President              27\n",
            "Testicle Monster A     26\n",
            "Cop Rick               26\n",
            "Principal Vagina       25\n",
            "Snuffles               22\n",
            "Name: count, dtype: int64\n"
          ]
        }
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "# Убираем все лишнее из реплик\n",
        "def preprocess_text(text):\n",
        "    if not isinstance(text, str):\n",
        "        return ''\n",
        "    # Убираем ремарки в скобках\n",
        "    text = re.sub(r'\\([^)]*\\)', '', text)\n",
        "    text = re.sub(r'\\[[^\\]]*\\]', '', text)\n",
        "\n",
        "    # Убираем лишние пробелы и символы\n",
        "    text = re.sub(r'[\\x00-\\x1f\\x7f]', ' ', text)\n",
        "    text = re.sub(r' +', ' ', text).strip()\n",
        "    return text"
      ],
      "metadata": {
        "id": "TTFbcRFFj_Ua"
      },
      "execution_count": 6,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "source": [
        "Оставим только строки с персонажем Рика. Помимо того, что это было ознечено как цель работы, мы получаем дополнительные плюсы: больше данных, чем у других персонажей, а также более \"характерные\" реплики"
      ],
      "metadata": {
        "id": "GX24VXz9xvUB"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "# Оставим также и другие вариации Рика\n",
        "rick_names = {'Rick', 'Pickle Rick', 'All Ricks', 'Cop Rick'}\n",
        "rick_mask = df_raw['name'].str.strip().isin(rick_names)\n",
        "df_rick = df_raw[rick_mask][['name', 'line']].copy()\n",
        "df_rick.columns = ['character', 'line']"
      ],
      "metadata": {
        "id": "_0okuiOnkIz3"
      },
      "execution_count": 7,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "# Убирем слишком короткие и слишком длинные реплики\n",
        "df_rick['line_clean'] = df_rick['line'].apply(preprocess_text)\n",
        "word_counts = df_rick['line_clean'].str.split().str.len()\n",
        "df_rick = df_rick[\n",
        "    (word_counts >= 5) &\n",
        "    (df_rick['line_clean'].str.len() <= 300) &\n",
        "    (df_rick['line_clean'].str.len() > 0)\n",
        "].drop_duplicates(subset='line_clean').reset_index(drop=True)\n",
        "\n",
        "print(f' Количество реплик Рика после очистки: {len(df_rick)}')\n",
        "print()\n",
        "print('Примеры реплик:')\n",
        "for i, row in df_rick.sample(5, random_state=42).iterrows():\n",
        "    print(f'{i}. {row[\"line_clean\"]}')"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "VJhcpz8_mMc7",
        "outputId": "9c16b155-8b1a-4711-df34-c7809e50938f"
      },
      "execution_count": 8,
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            " Количество реплик Рика после очистки: 451\n",
            "\n",
            "Примеры реплик:\n",
            "298. Come on, flip the pickle, Morty. You're not gonna regret it. The payoff is huge.\n",
            "39. Don't worry about it, Morty. Just come help me get these seeds, all right, buddy?\n",
            "335. There's nothing I won't do to see her again.\n",
            "398. Because my epidermis is laced with a nanofiber defense mesh.\n",
            "153. Shut up! Oh crap are you kidding me? Two dots? This never needs to be more than one dot. The two of you made us uncertain!\n"
          ]
        }
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "# Статистики\n",
        "lengths = df_rick['line_clean'].str.len()\n",
        "words = df_rick['line_clean'].str.split().str.len()\n",
        "print(f'Статистика датасета: \\n')\n",
        "print(f'Реплик: {len(df_rick)}')\n",
        "print(f'Средняя длина реплик в символах: {lengths.mean():.0f}')\n",
        "print(f'Средняя длина реплик в словах: {words.mean():.1f}')\n",
        "print(f'Минимум и максимум слов в одной реплике соответсвенно: {words.min()} и {words.max()}')\n",
        "\n",
        "df_rick.to_csv('rick_lines.csv', index=False)\n",
        "print('Обработанный датасет сохранён в файле rick_lines.csv')"
      ],
