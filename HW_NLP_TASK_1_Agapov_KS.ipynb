        "def compare_search(query: str, top_k: int = 3) -> None:\n",
        "    \"\"\"Сравнивает результаты векторного и ключевого поиска.\"\"\"\n",
        "    print(f'\\n Запрос: \"{query}\"')\n",
        "\n",
        "    vec_results = vector_search(query, top_k=top_k)\n",
        "    bm_results  = bm25_search(query, top_k=top_k)\n",
        "\n",
        "    print(f'Vector Search:')\n",
        "    for r in vec_results:\n",
        "        print(f'     [{r[\"rank\"]}] sim={r[\"score\"]:.4f} | {r[\"line\"][:80]}...'\n",
        "              if len(r['line']) > 80 else f'     [{r[\"rank\"]}] sim={r[\"score\"]:.4f} | {r[\"line\"]}')\n",
        "\n",
        "    print(f'BM25 Keyword Search:')\n",
        "    for r in bm_results:\n",
        "        bm_score_norm = r['score'] / (max(r['score'], 1))  # нормализуем\n",
        "        print(f'     [{r[\"rank\"]}] score={r[\"score\"]:.2f}  | {r[\"line\"][:80]}...'\n",
        "              if len(r['line']) > 80 else f'     [{r[\"rank\"]}] score={r[\"score\"]:.2f}  | {r[\"line\"]}')\n",
        "\n",
        "\n",
        "print('Сравнение Vector Search и Keyword Search (BM25)')"
